{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CampusSync",
  "version": "6.0.1",
  "identifier": "com.campussync.mobile",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3033",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "CampusSync Mobile",
        "width": 375,
        "height": 812,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}